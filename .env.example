# PlanMyPickle backend — environment configuration.
# Copy to .env for local dev (.env is gitignored). On Railway, set these as
# service variables in the dashboard. The backend refuses to start without the
# two Supabase values below.

# --- Required: Supabase (the sole data store) ---
# Project URL, e.g. https://<ref>.supabase.co
SUPABASE_URL=
# service_role key (NOT the anon key — RLS blocks anon). Keep this secret.
SUPABASE_SERVICE_KEY=

# --- Optional ---
# Listen address. Leave unset on Railway: it injects $PORT and the app binds to it.
# PMP_ADDR=:8080
# Google Places key for the nearby-courts venue picker (falls back to free OSM).
# PMP_PLACES_KEY=
